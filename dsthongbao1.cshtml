       function startTime() {
           const today = new Date();
           let h = today.getHours();
           let m = today.getMinutes();
           let s = today.getSeconds();
           let n = today.getDate();
           let t = today.getMonth()+1;
           let thu = today.getDay();
           let nam = today.getFullYear();
           m = checkTime(m);
           s = checkTime(s);
           //let c = 0;

           //let t1 = checkt(c);
           //alert(t1);
           //let z = today.getMonth();
           //alert(z);
           t = checkt(t);
           t = checknt(t);
           n = checknt(n);

